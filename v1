<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX — Elite Productivity System</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #C9A84C;
    --gold-light: #E8C96A;
    --gold-dim: #8A6B2A;
    --gold-bg: rgba(201,168,76,0.08);
    --gold-bg-hover: rgba(201,168,76,0.14);
    --surface-0: #0A0A0B;
    --surface-1: #111113;
    --surface-2: #18181B;
    --surface-3: #222227;
    --surface-4: #2C2C33;
    --text-primary: #F0EDE6;
    --text-secondary: #9B9790;
    --text-muted: #5C5A56;
    --border: rgba(201,168,76,0.12);
    --border-strong: rgba(201,168,76,0.25);
    --red: #C0392B;
    --red-bg: rgba(192,57,43,0.12);
    --green: #2ECC71;
    --green-bg: rgba(46,204,113,0.1);
    --blue: #5B8CDB;
    --blue-bg: rgba(91,140,219,0.1);
    --amber: #E67E22;
    --amber-bg: rgba(230,126,34,0.1);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-ui: 'Outfit', sans-serif;
    --font-mono: 'DM Mono', monospace;
    --nav-w: 220px;
    --radius: 10px;
    --radius-lg: 16px;
  }

  html, body { height: 100%; background: var(--surface-0); color: var(--text-primary); font-family: var(--font-ui); font-size: 14px; line-height: 1.6; }

  /* LAYOUT */
  .app { display: flex; height: 100vh; overflow: hidden; }

  /* SIDEBAR */
  .sidebar {
    width: var(--nav-w);
    background: var(--surface-1);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    padding: 0;
    z-index: 10;
  }
  .sidebar-logo {
    padding: 28px 24px 20px;
    border-bottom: 1px solid var(--border);
  }
  .logo-word {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--gold);
    line-height: 1;
  }
  .logo-sub {
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    font-weight: 400;
    margin-top: 4px;
    text-transform: uppercase;
  }
  .sidebar-nav { flex: 1; padding: 16px 12px; display: flex; flex-direction: column; gap: 2px; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.01em;
    transition: all 0.15s ease;
    border: 1px solid transparent;
    user-select: none;
  }
  .nav-item:hover { background: var(--gold-bg); color: var(--text-primary); }
  .nav-item.active {
    background: var(--gold-bg);
    color: var(--gold);
    border-color: var(--border);
    font-weight: 500;
  }
  .nav-icon { font-size: 15px; width: 18px; text-align: center; flex-shrink: 0; }
  .nav-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); margin-left: auto; flex-shrink: 0; }

  .sidebar-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .sidebar-date { color: var(--gold-dim); font-family: var(--font-mono); font-size: 11px; }

  /* MAIN */
  .main { flex: 1; overflow-y: auto; background: var(--surface-0); }
  .page { display: none; padding: 40px 44px; min-height: 100%; }
  .page.active { display: block; }

  /* PAGE HEADER */
  .page-header { margin-bottom: 36px; }
  .page-title { font-family: var(--font-display); font-size: 36px; font-weight: 300; color: var(--text-primary); line-height: 1.1; letter-spacing: -0.01em; }
  .page-title span { color: var(--gold); font-style: italic; }
  .page-sub { font-size: 12px; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 6px; }

  /* GOLD DIVIDER */
  .gold-line { height: 1px; background: linear-gradient(90deg, var(--gold) 0%, transparent 100%); margin: 0 0 32px; width: 80px; }

  /* KPI GRID */
  .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
  .kpi-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .kpi-card:hover { border-color: var(--border-strong); }
  .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--accent, var(--gold)); opacity: 0.6; }
  .kpi-label { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 10px; }
  .kpi-value { font-family: var(--font-display); font-size: 38px; font-weight: 300; color: var(--text-primary); line-height: 1; }
  .kpi-value .unit { font-size: 18px; color: var(--text-secondary); margin-left: 2px; }
  .kpi-sub { font-size: 11px; color: var(--text-secondary); margin-top: 6px; }
  .kpi-sub .up { color: var(--green); }
  .kpi-sub .down { color: var(--red); }

  /* DASHBOARD GRID */
  .dash-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; }
  .dash-grid-full { display: grid; grid-template-columns: 1fr; gap: 24px; }

  /* CARD */
  .card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px 26px;
  }
  .card-title {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .card-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* PROGRESS RINGS */
  .rings-row { display: flex; justify-content: space-around; align-items: center; padding: 8px 0; }
  .ring-item { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .ring-label { font-size: 11px; color: var(--text-secondary); letter-spacing: 0.05em; text-align: center; }
  .ring-wrapper { position: relative; width: 90px; height: 90px; }
  .ring-svg { width: 90px; height: 90px; transform: rotate(-90deg); }
  .ring-bg { fill: none; stroke: var(--surface-4); stroke-width: 6; }
  .ring-fill { fill: none; stroke-width: 6; stroke-linecap: round; transition: stroke-dashoffset 1s cubic-bezier(0.4,0,0.2,1); }
  .ring-pct {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    font-family: var(--font-display); font-size: 22px; font-weight: 300; color: var(--text-primary);
    line-height: 1;
  }

  /* TASK LIST */
  .task-list { display: flex; flex-direction: column; gap: 2px; }
  .task-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--surface-3);
    cursor: pointer;
    transition: padding-left 0.15s;
  }
  .task-row:last-child { border-bottom: none; }
  .task-row:hover { padding-left: 4px; }
  .task-check {
    width: 16px; height: 16px; border-radius: 50%;
    border: 1.5px solid var(--border-strong);
    flex-shrink: 0;
    cursor: pointer;
    transition: all 0.15s;
    display: flex; align-items: center; justify-content: center;
  }
  .task-check.done { background: var(--gold); border-color: var(--gold); }
  .task-check.done::after { content: '✓'; font-size: 9px; color: #000; font-weight: 700; }
  .task-name { flex: 1; font-size: 13px; color: var(--text-primary); }
  .task-name.done { text-decoration: line-through; color: var(--text-muted); }
  .task-meta { display: flex; align-items: center; gap: 8px; }
  .task-tag {
    font-size: 10px; padding: 2px 8px; border-radius: 20px;
    letter-spacing: 0.04em;
    background: var(--gold-bg); color: var(--gold-dim); border: 1px solid var(--border);
  }
  .task-tag.high { background: var(--red-bg); color: #E87070; border-color: rgba(192,57,43,0.25); }
  .task-tag.med { background: var(--amber-bg); color: var(--amber); border-color: rgba(230,126,34,0.25); }
  .task-tag.low { background: var(--blue-bg); color: var(--blue); border-color: rgba(91,140,219,0.25); }
  .task-tag.done-tag { background: var(--green-bg); color: var(--green); border-color: rgba(46,204,113,0.2); }
  .task-hrs { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }

  /* WEEK BAR */
  .week-bars { display: flex; align-items: flex-end; gap: 8px; height: 80px; }
  .week-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .week-bar-bg { width: 100%; background: var(--surface-4); border-radius: 4px; height: 64px; display: flex; align-items: flex-end; overflow: hidden; }
  .week-bar-fill { width: 100%; background: var(--gold); border-radius: 4px; transition: height 0.8s cubic-bezier(0.4,0,0.2,1); opacity: 0.7; }
  .week-bar-fill.today { opacity: 1; }
  .week-bar-day { font-size: 10px; color: var(--text-muted); letter-spacing: 0.05em; }
  .week-bar-day.today { color: var(--gold); }

  /* FOCUS TIMER */
  .timer-display {
    text-align: center;
    padding: 30px 0 20px;
  }
  .timer-time {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .timer-time.running { color: var(--gold); }
  .timer-label { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-top: 8px; }
  .timer-controls { display: flex; justify-content: center; gap: 12px; margin-top: 20px; }
  .btn {
    padding: 9px 22px;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn:hover { background: var(--gold-bg); border-color: var(--gold); color: var(--gold); }
  .btn.primary { background: var(--gold); color: #000; border-color: var(--gold); font-weight: 600; }
  .btn.primary:hover { background: var(--gold-light); }
  .btn.danger { border-color: rgba(192,57,43,0.4); color: #E87070; }
  .btn.danger:hover { background: var(--red-bg); }
  .timer-presets { display: flex; justify-content: center; gap: 8px; margin-top: 14px; }
  .preset-btn {
    font-size: 11px; padding: 4px 12px;
    border-radius: 20px; border: 1px solid var(--border);
    background: transparent; color: var(--text-secondary);
    cursor: pointer; transition: all 0.15s; font-family: var(--font-mono);
  }
  .preset-btn:hover, .preset-btn.active { border-color: var(--gold); color: var(--gold); background: var(--gold-bg); }

  /* ACTIVITY LOG */
  .log-list { display: flex; flex-direction: column; gap: 0; }
  .log-item {
    display: flex; gap: 14px; padding: 12px 0;
    border-bottom: 1px solid var(--surface-3);
    align-items: flex-start;
  }
  .log-item:last-child { border-bottom: none; }
  .log-time { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); flex-shrink: 0; padding-top: 2px; min-width: 50px; }
  .log-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 6px; }
  .log-content { flex: 1; }
  .log-task { font-size: 13px; color: var(--text-primary); }
  .log-dur { font-size: 11px; color: var(--text-secondary); margin-top: 2px; font-family: var(--font-mono); }

  /* FORM ELEMENTS */
  .form-row { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
  .form-label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
  .form-input {
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  .form-input:focus { border-color: var(--gold); }
  .form-input::placeholder { color: var(--text-muted); }
  select.form-input { cursor: pointer; }
  textarea.form-input { resize: vertical; min-height: 80px; line-height: 1.6; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  /* ADD TASK FORM */
  .add-form { background: var(--surface-1); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; margin-bottom: 24px; }
  .add-form-title { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }

  /* WINS */
  .wins-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
  .win-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
  }
  .win-card-title { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold-dim); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
  .win-card-title span { font-size: 14px; }
  .win-list { display: flex; flex-direction: column; gap: 8px; }
  .win-item { font-size: 13px; color: var(--text-secondary); padding-left: 14px; position: relative; }
  .win-item::before { content: '—'; position: absolute; left: 0; color: var(--gold-dim); }

  /* QUOTE */
  .quote-block {
    background: var(--gold-bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 18px 22px;
    margin-top: 24px;
  }
  .quote-text { font-family: var(--font-display); font-size: 18px; font-style: italic; color: var(--text-primary); font-weight: 300; line-height: 1.5; }
  .quote-author { font-size: 11px; color: var(--text-muted); letter-spacing: 0.08em; margin-top: 8px; }

  /* WEEKLY PLAN */
  .week-plan-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 24px; }
  .day-col {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
  }
  .day-col.today { border-color: var(--gold); }
  .day-name { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }
  .day-col.today .day-name { color: var(--gold); }
  .day-task {
    font-size: 12px; color: var(--text-secondary); padding: 7px 10px;
    background: var(--surface-3); border-radius: 6px; margin-bottom: 6px;
    cursor: pointer; transition: all 0.15s; line-height: 1.4;
  }
  .day-task:hover { background: var(--surface-4); color: var(--text-primary); }
  .day-task.done-t { text-decoration: line-through; opacity: 0.4; }
  .day-add { font-size: 11px; color: var(--text-muted); padding: 6px 10px; text-align: center; cursor: pointer; border-radius: 6px; border: 1px dashed var(--border); margin-top: 4px; }
  .day-add:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-bg); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--surface-4); border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--gold-dim); }

  /* FOCUS BAR TOP */
  .focus-bar {
    background: var(--surface-1);
    border-bottom: 1px solid var(--border);
    padding: 10px 44px;
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 12px;
    color: var(--text-muted);
    position: sticky; top: 0; z-index: 5;
  }
  .focus-bar-date { font-family: var(--font-mono); color: var(--gold-dim); }
  .focus-bar-sep { color: var(--border-strong); }
  .focus-bar-status { display: flex; align-items: center; gap: 6px; }
  .status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .focus-bar-right { margin-left: auto; display: flex; align-items: center; gap: 16px; }
  .focus-timer-mini { font-family: var(--font-mono); font-size: 13px; color: var(--gold); }
  .focus-timer-mini.stopped { color: var(--text-muted); }

  /* EMPTY STATE */
  .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 13px; }

  /* WORKLOG TABLE */
  .log-table { width: 100%; border-collapse: collapse; }
  .log-table th { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
  .log-table td { padding: 12px 12px; border-bottom: 1px solid var(--surface-3); font-size: 13px; color: var(--text-secondary); vertical-align: top; }
  .log-table tr:last-child td { border-bottom: none; }
  .log-table tr:hover td { background: var(--surface-3); color: var(--text-primary); }
  .log-table .td-task { color: var(--text-primary); }
  .log-table .td-time { font-family: var(--font-mono); font-size: 11px; }
  .log-table .td-dur { font-family: var(--font-mono); font-size: 11px; color: var(--gold-dim); }
</style>
</head>
<body>
<div class="app">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-word">APEX</div>
      <div class="logo-sub">Elite Productivity System</div>
    </div>
    <div class="sidebar-nav">
      <div class="nav-item active" onclick="showPage('dashboard', this)">
        <span class="nav-icon">◈</span> Dashboard
        <span class="nav-dot"></span>
      </div>
      <div class="nav-item" onclick="showPage('tasks', this)">
        <span class="nav-icon">◻</span> Task Master
      </div>
      <div class="nav-item" onclick="showPage('worklog', this)">
        <span class="nav-icon">◎</span> Work Log
      </div>
      <div class="nav-item" onclick="showPage('weekly', this)">
        <span class="nav-icon">▦</span> Weekly Plan
      </div>
      <div class="nav-item" onclick="showPage('wins', this)">
        <span class="nav-icon">◆</span> Wins & Review
      </div>
    </div>
    <div class="sidebar-footer">
      <div class="sidebar-date" id="sidebar-date"></div>
      <div style="margin-top:4px; font-size:10px;">Week 12 · Q1 2026</div>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main" id="main">

    <!-- TOP BAR -->
    <div class="focus-bar">
      <span class="focus-bar-date" id="topbar-date"></span>
      <span class="focus-bar-sep">·</span>
      <span class="focus-bar-status">
        <span class="status-dot"></span>
        Active session
      </span>
      <div class="focus-bar-right">
        <span style="font-size:11px; color: var(--text-muted);">Focus timer:</span>
        <span class="focus-timer-mini stopped" id="topbar-timer">00:00</span>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!-- PAGE: DASHBOARD -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="page active" id="page-dashboard">
      <div class="page-header">
        <div class="page-title">Good morning, <span>Executive.</span></div>
        <div class="page-sub">Your command center · Thursday, March 19</div>
      </div>
      <div class="gold-line"></div>

      <!-- KPI ROW -->
      <div class="kpi-grid">
        <div class="kpi-card" style="--accent: var(--gold)">
          <div class="kpi-label">Tasks Active</div>
          <div class="kpi-value" id="kpi-active">7</div>
          <div class="kpi-sub"><span class="down">↑ 2</span> from yesterday</div>
        </div>
        <div class="kpi-card" style="--accent: var(--green)">
          <div class="kpi-label">Completed Today</div>
          <div class="kpi-value" id="kpi-done">3</div>
          <div class="kpi-sub"><span class="up">↑ 1</span> vs daily avg</div>
        </div>
        <div class="kpi-card" style="--accent: var(--blue)">
          <div class="kpi-label">Hours Logged</div>
          <div class="kpi-value" id="kpi-hours">4<span class="unit">h</span></div>
          <div class="kpi-sub">of 8h target</div>
        </div>
        <div class="kpi-card" style="--accent: var(--amber)">
          <div class="kpi-label">Focus Score</div>
          <div class="kpi-value" id="kpi-score">82<span class="unit">%</span></div>
          <div class="kpi-sub"><span class="up">↑ 12%</span> this week</div>
        </div>
      </div>

      <!-- MAIN DASH GRID -->
      <div class="dash-grid">

        <!-- LEFT: Progress Rings + Priority Tasks -->
        <div style="display:flex; flex-direction:column; gap:20px;">

          <!-- Progress Rings -->
          <div class="card">
            <div class="card-title">Weekly Progress</div>
            <div class="rings-row">
              <div class="ring-item">
                <div class="ring-wrapper">
                  <svg class="ring-svg" viewBox="0 0 90 90">
                    <circle class="ring-bg" cx="45" cy="45" r="38"/>
