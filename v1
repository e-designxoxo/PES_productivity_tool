<script>
// ═══════════════════════════════════════
// DATA
// ═══════════════════════════════════════
const tasks = [
  { id: 1, name: 'Q2 strategic planning deck', cat: 'Strategy', priority: 'high', hrs: 4, action: 'Draft executive summary first', done: false },
  { id: 2, name: 'Competitive landscape analysis', cat: 'Research', priority: 'high', hrs: 3, action: 'Pull industry reports', done: false },
  { id: 3, name: 'Investor update memo', cat: 'Comms', priority: 'high', hrs: 2, action: 'Outline key metrics', done: true },
  { id: 4, name: 'Weekly team OKR review', cat: 'Operations', priority: 'med', hrs: 1, action: 'Prepare talking points', done: false },
  { id: 5, name: 'Product roadmap refinement', cat: 'Strategy', priority: 'med', hrs: 2.5, action: 'Review backlog with PM', done: false },
  { id: 6, name: 'Finance model update', cat: 'Operations', priority: 'med', hrs: 1.5, action: 'Update Q1 actuals', done: true },
  { id: 7, name: 'Client onboarding email sequence', cat: 'Comms', priority: 'low', hrs: 1, action: 'Write draft in Notion', done: true },
  { id: 8, name: 'Research AI workflow tools', cat: 'Research', priority: 'low', hrs: 1.5, action: 'Start with Perplexity search', done: false },
];

const workLogs = [
  { time: '09:15', task: 'Q2 Strategic Deck', notes: 'Completed exec summary and market analysis section', duration: 90 },
  { time: '11:00', task: 'Investor Memo', notes: 'Drafted financial highlights, pending CFO review', duration: 45 },
  { time: '13:30', task: 'Team OKR Prep', notes: 'Compiled KPIs from all team leads', duration: 30 },
  { time: '14:15', task: 'Competitive Research', notes: 'Analyzed 4 competitor pricing models', duration: 60 },
  { time: '16:00', task: 'Finance Model', notes: 'Updated Q1 actuals, corrected revenue line', duration: 40 },
];

const weekDays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'];
const weekData = [6.5, 7.2, 5.8, 4.0, null]; // hours worked, today = index 3
const todayIdx = 3;

let taskFilter = 'all';
let nextTaskId = tasks.length + 1;
let nextLogId = workLogs.length + 1;

// ═══════════════════════════════════════
// TIMER
// ═══════════════════════════════════════
let timerInterval = null;
let timerSeconds = 25 * 60;
let timerTotal = 25 * 60;
let timerRunning = false;
let focusSessionSeconds = 0;
let focusInterval = null;

function fmtTime(s) {
  const m = Math.floor(s / 60).toString().padStart(2, '0');
  const sc = (s % 60).toString().padStart(2, '0');
  return `${m}:${sc}`;
}

function setTimer(mins, btn) {
  if (timerRunning) return;
  timerSeconds = mins * 60;
  timerTotal = mins * 60;
  document.getElementById('timer-display').textContent = fmtTime(timerSeconds);
  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
}

function toggleTimer() {
  const btn = document.getElementById('timer-btn');
  const display = document.getElementById('timer-display');
  const label = document.getElementById('timer-label');
  if (!timerRunning) {
    timerRunning = true;
    btn.textContent = 'Pause';
    display.classList.add('running');
    label.textContent = 'In flow — stay locked in';
    timerInterval = setInterval(() => {
      timerSeconds--;
      display.textContent = fmtTime(timerSeconds);
      document.getElementById('topbar-timer').textContent = fmtTime(timerSeconds);
      document.getElementById('topbar-timer').classList.remove('stopped');
      if (timerSeconds <= 0) {
        clearInterval(timerInterval);
        timerRunning = false;
        btn.textContent = 'Start';
        display.classList.remove('running');
        label.textContent = 'Session complete — well done';
        display.textContent = '00:00';
      }
    }, 1000);
    // focus session counter
    if (!focusInterval) {
      focusInterval = setInterval(() => { focusSessionSeconds++; }, 1000);
    }
  } else {
    timerRunning = false;
    clearInterval(timerInterval);
    btn.textContent = 'Resume';
    display.classList.remove('running');
    label.textContent = 'Paused — pick it up when ready';
  }
}

function resetTimer() {
  clearInterval(timerInterval);
  timerRunning = false;
  timerSeconds = timerTotal;
  document.getElementById('timer-display').textContent = fmtTime(timerSeconds);
  document.getElementById('timer-display').classList.remove('running');
  document.getElementById('timer-btn').textContent = 'Start';
  document.getElementById('timer-label').textContent = 'Ready to focus';
  document.getElementById('topbar-timer').textContent = '00:00';
  document.getElementById('topbar-timer').classList.add('stopped');
}

// ═══════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════
function showPage(id, navEl) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  if (navEl) navEl.classList.add('active');
  // remove dot from all, add to active
  document.querySelectorAll('.nav-dot').forEach(d => d.remove());
  if (navEl) {
    const dot = document.createElement('span');
    dot.className = 'nav-dot';
    navEl.appendChild(dot);
  }
}

// ═══════════════════════════════════════
// RENDER TASKS
// ═══════════════════════════════════════
function renderDashTasks() {
  const el = document.getElementById('dash-tasks');
  const top = tasks.filter(t => !t.done).slice(0, 5);
  el.innerHTML = top.map(t => `
    <div class="task-row" onclick="toggleTask(${t.id})">
      <div class="task-check ${t.done ? 'done' : ''}"></div>
      <div class="task-name ${t.done ? 'done' : ''}">${t.name}</div>
      <div class="task-meta">
        <span class="task-tag ${t.priority}">${t.priority.toUpperCase()}</span>
        <span class="task-hrs">${t.hrs}h</span>
      </div>
    </div>
  `).join('');
}

function renderAllTasks() {
  const el = document.getElementById('all-tasks');
  let filtered = taskFilter === 'all' ? tasks : tasks.filter(t => t.priority === taskFilter);
  if (!filtered.length) { el.innerHTML = '<div class="empty-state">No tasks. Add one above.</div>'; return; }
  el.innerHTML = filtered.map(t => `
    <div class="task-row">
      <div class="task-check ${t.done ? 'done' : ''}" onclick="toggleTask(${t.id})"></div>
      <div style="flex:1">
        <div class="task-name ${t.done ? 'done' : ''}">${t.name}</div>
        <div style="font-size:11px; color:var(--text-muted); margin-top:2px;">Next: ${t.action}</div>
      </div>
      <div class="task-meta">
        <span class="task-tag">${t.cat}</span>
        <span class="task-tag ${t.priority}">${t.priority.toUpperCase()}</span>
        <span class="task-hrs">${t.hrs}h</span>
        ${t.done ? '<span class="task-tag done-tag">DONE</span>' : ''}
      </div>
    </div>
  `).join('');
}

function toggleTask(id) {
  const t = tasks.find(t => t.id === id);
  if (t) { t.done = !t.done; }
  renderDashTasks();
  renderAllTasks();
  updateKPIs();
}

function addTask() {
  const name = document.getElementById('new-task-name').value.trim();
  if (!name) return;
  tasks.push({
    id: nextTaskId++,
    name,
    cat: document.getElementById('new-task-cat').value,
    priority: document.getElementById('new-task-priority').value,
    hrs: parseFloat(document.getElementById('new-task-hrs').value) || 1,
    action: document.getElementById('new-task-action').value || '—',
    done: false
  });
  document.getElementById('new-task-name').value = '';
  document.getElementById('new-task-hrs').value = '';
  document.getElementById('new-task-action').value = '';
  renderAllTasks();
  renderDashTasks();
  updateKPIs();
}

function filterTasks(f, btn) {
  taskFilter = f;
  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  renderAllTasks();
}

// ═══════════════════════════════════════
// WORK LOG
// ═══════════════════════════════════════
function renderLogTable() {
  const tbody = document.getElementById('log-table-body');
  tbody.innerHTML = [...workLogs].reverse().map(l => `
    <tr>
      <td class="td-time">${l.time}</td>
      <td class="td-task">${l.task}</td>
      <td>${l.notes}</td>
      <td class="td-dur">${l.duration}m</td>
    </tr>
  `).join('');
}

function renderDashLog() {
  const el = document.getElementById('dash-log');
  const recent = [...workLogs].reverse().slice(0, 4);
  el.innerHTML = recent.map(l => `
    <div class="log-item">
      <div class="log-time">${l.time}</div>
      <div class="log-dot"></div>
      <div class="log-content">
        <div class="log-task">${l.task}</div>
        <div class="log-dur">${l.duration} min · ${l.notes.substring(0, 50)}${l.notes.length > 50 ? '…' : ''}</div>
      </div>
    </div>
  `).join('');
}

function logSession() {
  const task = document.getElementById('log-task').value.trim();
  const dur = parseInt(document.getElementById('log-duration').value);
  const notes = document.getElementById('log-notes').value.trim();
  if (!task || !dur) return;
  const now = new Date();
  const time = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
  workLogs.push({ id: nextLogId++, time, task, notes, duration: dur });
  document.getElementById('log-task').value = '';
  document.getElementById('log-duration').value = '';
  document.getElementById('log-notes').value = '';
  renderLogTable();
  renderDashLog();
  updateLogKPIs();
}

function updateLogKPIs() {
  const todayLogs = workLogs;
  document.getElementById('log-sessions-today').textContent = todayLogs.length;
  document.getElementById('log-mins-today').textContent = todayLogs.reduce((a, l) => a + l.duration, 0);
  document.getElementById('log-sessions-week').textContent = todayLogs.length + 14;
  const totalHrs = Math.floor(todayLogs.reduce((a, l) => a + l.duration, 0) / 60) + 20;
  document.getElementById('log-total-hrs').innerHTML = totalHrs + '<span class="kpi-value unit" style="font-size:18px">h</span>';
}

// ═══════════════════════════════════════
// WEEK CHART
// ═══════════════════════════════════════
function renderWeekChart() {
  const el = document.getElementById('week-chart');
  const maxH = Math.max(...weekData.filter(v => v !== null));
  el.innerHTML = weekData.map((val, i) => {
    const pct = val ? Math.round((val / 8) * 100) : 0;
    const h = val ? Math.round((val / maxH) * 64) : 0;
    const isToday = i === todayIdx;
    return `
      <div class="week-bar-wrap">
        <div class="week-bar-bg">
          <div class="week-bar-fill ${isToday ? 'today' : ''}" style="height:${h}px"></div>
        </div>
        <div class="week-bar-day ${isToday ? 'today' : ''}">${weekDays[i]}</div>
      </div>
    `;
  }).join('');
}

// ═══════════════════════════════════════
// WEEKLY PLAN
// ═══════════════════════════════════════
const weekPlanData = {
  'Mon': ['Prepare board briefing', 'Review contracts', 'Team standup'],
  'Tue': ['Deep work: Strategy deck', 'Investor call @ 3pm', 'Email triage'],
  'Wed': ['Product roadmap session', 'Competitive research', 'Coaching call'],
  'Thu': ['Q2 planning deep dive', 'Work log review', 'Priority reassessment'],
  'Fri': ['Weekly review', 'Wins documentation', 'Plan next week']
};

function renderWeeklyPlan() {
  const el = document.getElementById('week-plan-grid');
  el.innerHTML = weekDays.map((day, i) => {
    const isToday = i === todayIdx;
    const dayTasks = weekPlanData[day] || [];
    return `
      <div class="day-col ${isToday ? 'today' : ''}">
        <div class="day-name">${day}${isToday ? ' · Today' : ''}</div>
        ${dayTasks.map(t => `<div class="day-task" onclick="this.classList.toggle('done-t')">${t}</div>`).join('')}
        <div class="day-add" onclick="promptDayTask('${day}')">+ add</div>
      </div>
    `;
  }).join('');
}

function promptDayTask(day) {
  const t = prompt(`Add task to ${day}:`);
  if (t && t.trim()) {
    weekPlanData[day] = weekPlanData[day] || [];
    weekPlanData[day].push(t.trim());
    renderWeeklyPlan();
  }
}

// ═══════════════════════════════════════
// KPIs
// ═══════════════════════════════════════
function updateKPIs() {
  const active = tasks.filter(t => !t.done).length;
  const done = tasks.filter(t => t.done).length;
  document.getElementById('kpi-active').textContent = active;
  document.getElementById('kpi-done').textContent = done;
}

// ═══════════════════════════════════════
// DATE / TIME
// ═══════════════════════════════════════
function updateDateDisplay() {
  const now = new Date();
  const opts = { weekday: 'short', month: 'short', day: 'numeric' };
  const str = now.toLocaleDateString('en-GB', opts).toUpperCase();
  const el = document.getElementById('sidebar-date');
  if (el) el.textContent = str;
  const el2 = document.getElementById('topbar-date');
  if (el2) el2.textContent = 'THU 19 MAR 2026';
}

// ═══════════════════════════════════════
// WINS
// ═══════════════════════════════════════
function saveReview() {
  const win = document.getElementById('review-win').value.trim();
  if (win) {
    const list = document.getElementById('wins-list');
    const item = document.createElement('div');
    item.className = 'win-item';
    item.textContent = win;
    list.appendChild(item);
  }
  const learning = document.getElementById('review-learning').value.trim();
  if (learning) {
    const list = document.getElementById('lessons-list');
    const item = document.createElement('div');
    item.className = 'win-item';
    item.textContent = learning;
    list.appendChild(item);
  }
  document.getElementById('review-win').value = '';
  document.getElementById('review-learning').value = '';
  document.getElementById('review-adjust').value = '';
  document.getElementById('review-energy').value = '';
}

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
function init() {
  updateDateDisplay();
  renderDashTasks();
  renderAllTasks();
  renderLogTable();
  renderDashLog();
  renderWeekChart();
  renderWeeklyPlan();
  updateKPIs();
  updateLogKPIs();
}

init();
</script>
</body>
</html>
